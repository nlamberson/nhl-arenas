# .env example file for Frontend - Copy this file to .env and update with your values
# Command: cp .env.example .env

# API URL for connecting to the backend (no trailing slash).
# Keep comments on their own line — Expo's env loader does NOT strip inline "#" comments
# from values, which produces an invalid URL and axios "Network Error".
EXPO_PUBLIC_API_URL=http://localhost:8000

# Firebase Web API key — used to refresh id_token on 401 (same key as backend FIREBASE_API_KEY)
EXPO_PUBLIC_FIREBASE_API_KEY=

# Google OAuth Web client ID — Firebase Console → Authentication → Sign-in method → Google
# → Web SDK configuration. Required for "Continue with Google" on login/register.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: iOS OAuth client ID (Firebase Console → Project settings → Your apps → iOS app).
# Needed for Google Sign-In on physical iOS devices / TestFlight builds.
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google OAuth redirect URI setup (fix redirect_uri_mismatch):
# 1. Open Google Cloud Console → APIs & Services → Credentials
# 2. Edit the Web OAuth client (same ID as EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID)
# 3. Authorized JavaScript origins (web): http://localhost:8081
# 4. Authorized redirect URIs (web): http://localhost:8081/oauthredirect
#    Native dev build: com.example.nhlarenas:/oauthredirect
#    Check the Expo dev console for the exact URI logged at startup.